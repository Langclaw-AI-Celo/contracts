PRIVATE_KEY=
CELO_RPC_URL=https://forno.celo.org
# Backend helpers use CELO_CHAIN_RPC_URL plus CELO_DEPLOYER_PRIVATE_KEY or
# CELO_PRIVATE_KEY. This local contracts env stays minimal for direct forge runs.
# If you already sourced backend/.env first, map them with:
# export CELO_RPC_URL="${CELO_CHAIN_RPC_URL}"
# export PRIVATE_KEY="${CELO_DEPLOYER_PRIVATE_KEY:-$CELO_PRIVATE_KEY}"

# Current Celo mainnet proof registry.
LANGCLAW_REGISTRY_ADDRESS=0xe69755e4249c4978c39fbe847ca9674ce7af3505

# Celo USDT-backed usage vault deployment.
LANGCLAW_USAGE_VAULT_OWNER=
LANGCLAW_USAGE_VAULT_WITHDRAWAL_AUTHORITY=
LANGCLAW_USAGE_VAULT_DEPOSIT_TOKEN=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
LANGCLAW_USAGE_VAULT_ADDRESS=0x837a2948586de4e7638c742f99e520ffc049bcf7

# Optional AI Trading & Strategy journal deployment.
LANGCLAW_TRADING_JOURNAL_ADDRESS=0x69984c20176704685236fd633192d7de1c13a5ec

# Optional legacy Mantle deployment values.
MANTLE_RPC_URL=https://rpc.mantle.xyz
